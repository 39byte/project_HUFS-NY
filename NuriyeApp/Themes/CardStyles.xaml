<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════ Card Style (Border) ══════════ -->
    <Style x:Key="NuriyeCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource NuriyeSurfaceBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NuriyeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- Card Alt Style -->
    <Style x:Key="NuriyeCardAltStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource NuriyeSurfaceAltBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="{ThemeResource NuriyeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- ══════════ Section Header Style (TextBlock) ══════════ -->
    <Style x:Key="NuriyeSectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{ThemeResource NuriyeTextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

</ResourceDictionary>
