<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NuriyeApp.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer Padding="16">
        <StackPanel MaxWidth="400" Spacing="16">
            <TextBlock Text="설정"
                       Style="{StaticResource SubtitleTextBlockStyle}"/>

            <TextBlock Text="관리자 비밀번호 변경"
                       Style="{StaticResource BodyStrongTextBlockStyle}"/>

            <PasswordBox Header="현재 비밀번호"
                         Password="{x:Bind ViewModel.CurrentPassword, Mode=TwoWay}"
                         PlaceholderText="현재 비밀번호"/>

            <PasswordBox Header="새 비밀번호"
                         Password="{x:Bind ViewModel.NewPassword, Mode=TwoWay}"
                         PlaceholderText="새 비밀번호"/>

            <PasswordBox Header="새 비밀번호 확인"
                         Password="{x:Bind ViewModel.ConfirmPassword, Mode=TwoWay}"
                         PlaceholderText="새 비밀번호 다시 입력"/>

            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>

            <Button Content="비밀번호 변경"
                    Command="{x:Bind ViewModel.ChangePasswordCommand}"
                    IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                    Style="{StaticResource AccentButtonStyle}"/>

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</Page>
