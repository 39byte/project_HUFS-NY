<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NuriyeApp.Views.OngoingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NuriyeApp.Models"
    xmlns:controls="using:NuriyeApp.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- List -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="&#xC9C4;&#xD589; &#xC911; &#xB300;&#xC5EC;"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <Button Content="&#xC0C8;&#xB85C;&#xACE0;&#xCE68;"
                        Command="{x:Bind ViewModel.LoadCommand}"
                        Style="{StaticResource NuriyeDefaultButtonStyle}"/>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="20" Height="20"/>
            </StackPanel>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Rentals, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedRental, Mode=TwoWay}"
                      SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="CornerRadius" Value="10"/>
                        <Setter Property="Margin" Value="0,2"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Rental">
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- D-Day Badge -->
                            <controls:DDayBadge Grid.Column="0"
                                                DDayText="{x:Bind DDayLabel}"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}">
                                    <Run Text="{x:Bind Applicant}"/>
                                    <Run Text=" &#xB7; "/>
                                    <Run Text="{x:Bind Equipment}"/>
                                </TextBlock>
                                <TextBlock Foreground="{ThemeResource NuriyeTextSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}">
                                    <Run Text="{x:Bind StartDate}"/>
                                    <Run Text=" ~ "/>
                                    <Run Text="{x:Bind EndDate}"/>
                                </TextBlock>
                                <TextBlock Text="{x:Bind Staff}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource NuriyeTextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="2"
                       Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Margin="0,8,0,0"/>
        </Grid>

        <!-- Processing Panel -->
        <Border Grid.Column="1"
                Background="{ThemeResource NuriyeSurfaceAltBrush}"
                CornerRadius="12"
                Padding="16">
            <ScrollViewer>
                <StackPanel Spacing="12">
                    <TextBlock Text="&#xBC18;&#xB0A9; &#xCC98;&#xB9AC;"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <TextBox Header="&#xBE44;&#xACE0;"
                             Text="{x:Bind ViewModel.Remarks, Mode=TwoWay}"
                             PlaceholderText="&#xBE44;&#xACE0; &#xC785;&#xB825;"
                             AcceptsReturn="True"
                             Height="80"
                             TextWrapping="Wrap"
                             Style="{StaticResource NuriyeTextBoxStyle}"/>

                    <Button Content="&#xBE44;&#xACE0; &#xC800;&#xC7A5;"
                            Command="{x:Bind ViewModel.SaveRemarksCommand}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource NuriyeDefaultButtonStyle}"/>

                    <Button Content="&#xBC18;&#xB0A9; &#xC644;&#xB8CC; &#xCC98;&#xB9AC;"
                            Command="{x:Bind ViewModel.MarkReturnedCommand}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource NuriyeAccentButtonStyle}"/>

                    <Button Content="&#xB300;&#xAE30; &#xC0C1;&#xD0DC;&#xB85C; &#xB418;&#xB3CC;&#xB9AC;&#xAE30;"
                            Command="{x:Bind ViewModel.RevertToPendingCommand}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource NuriyeDefaultButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
