<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NuriyeApp.Views.OngoingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NuriyeApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 목록 -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="진행 중 대여"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <Button Content="새로고침" Command="{x:Bind ViewModel.LoadCommand}"/>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="20" Height="20"/>
            </StackPanel>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Rentals, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedRental, Mode=TwoWay}"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Rental">
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- D-Day 배지 -->
                            <Border Grid.Column="0"
                                    Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                                    CornerRadius="8"
                                    Padding="8,4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind DDayLabel}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}">
                                    <Run Text="{x:Bind Applicant}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{x:Bind Equipment}"/>
                                </TextBlock>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}">
                                    <Run Text="{x:Bind StartDate}"/>
                                    <Run Text=" ~ "/>
                                    <Run Text="{x:Bind EndDate}"/>
                                </TextBlock>
                                <TextBlock Text="{x:Bind Staff}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="2"
                       Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Margin="0,8,0,0"/>
        </Grid>

        <!-- 처리 패널 -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Spacing="12">
                <TextBlock Text="반납 처리"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>

                <TextBox Header="비고"
                         Text="{x:Bind ViewModel.Remarks, Mode=TwoWay}"
                         PlaceholderText="비고 입력"
                         AcceptsReturn="True"
                         Height="80"
                         TextWrapping="Wrap"/>

                <Button Content="비고 저장"
                        Command="{x:Bind ViewModel.SaveRemarksCommand}"
                        HorizontalAlignment="Stretch"/>

                <Button Content="반납 완료 처리"
                        Command="{x:Bind ViewModel.MarkReturnedCommand}"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource AccentButtonStyle}"/>

                <Button Content="대기 상태로 되돌리기"
                        Command="{x:Bind ViewModel.RevertToPendingCommand}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
