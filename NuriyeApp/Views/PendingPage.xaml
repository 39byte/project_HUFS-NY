<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NuriyeApp.Views.PendingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NuriyeApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 신청 목록 -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="승인 대기 목록"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <Button Content="새로고침"
                        Command="{x:Bind ViewModel.LoadCommand}"/>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="20" Height="20"/>
            </StackPanel>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Rentals, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedRental, Mode=TwoWay}"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Rental">
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{x:Bind Applicant}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind Contact}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{x:Bind Equipment}" TextWrapping="Wrap"/>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}">
                                    <Run Text="{x:Bind StartDate}"/>
                                    <Run Text=" ~ "/>
                                    <Run Text="{x:Bind EndDate}"/>
                                </TextBlock>
                                <TextBlock Text="{x:Bind Accessories}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind SubmittedAt}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Top"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="2"
                       Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Margin="0,8,0,0"
                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
        </Grid>

        <!-- 처리 패널 -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Spacing="12">
                <TextBlock Text="신청 처리"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>

                <TextBlock Text="선택된 신청이 없습니다."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="{x:Bind ViewModel.HasNoSelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                             x:Name="RentalInfoBar">
                        <InfoBar.Content>
                            <StackPanel Spacing="4" Padding="0,4,0,8">
                                <TextBlock Text="{x:Bind ViewModel.SelectedRental.Equipment, Mode=OneWay}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Bind ViewModel.SelectedRental.StartDate, Mode=OneWay}"/>
                                    <Run Text=" ~ "/>
                                    <Run Text="{x:Bind ViewModel.SelectedRental.EndDate, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{x:Bind ViewModel.SelectedRental.MeetingTime, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.SelectedRental.Accessories, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.SelectedRental.ExtraRequest, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                            </StackPanel>
                        </InfoBar.Content>
                    </InfoBar>

                    <ComboBox Header="담당자"
                              ItemsSource="{x:Bind ViewModel.StaffList}"
                              SelectedItem="{x:Bind ViewModel.SelectedStaff, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"/>

                    <TextBox Header="비고"
                             Text="{x:Bind ViewModel.Remarks, Mode=TwoWay}"
                             PlaceholderText="비고 입력 (선택)"
                             AcceptsReturn="True"
                             Height="80"
                             TextWrapping="Wrap"/>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="승인"
                                Command="{x:Bind ViewModel.ApproveCommand}"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"/>
                        <Button Grid.Column="1"
                                Content="반려"
                                Command="{x:Bind ViewModel.RejectCommand}"
                                HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
