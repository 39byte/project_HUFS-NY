<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NuriyeApp.Views.PendingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NuriyeApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Rental List -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="&#xC2B9;&#xC778; &#xB300;&#xAE30; &#xBAA9;&#xB85D;"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <Button Content="&#xC0C8;&#xB85C;&#xACE0;&#xCE68;"
                        Command="{x:Bind ViewModel.LoadCommand}"
                        Style="{StaticResource NuriyeDefaultButtonStyle}"/>
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="20" Height="20"/>
            </StackPanel>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Rentals, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedRental, Mode=TwoWay}"
                      SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="CornerRadius" Value="10"/>
                        <Setter Property="Margin" Value="0,2"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Rental">
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{x:Bind Applicant}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind Contact}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource NuriyeTextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{x:Bind Equipment}" TextWrapping="Wrap"/>
                                <TextBlock Foreground="{ThemeResource NuriyeTextSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}">
                                    <Run Text="{x:Bind StartDate}"/>
                                    <Run Text=" ~ "/>
                                    <Run Text="{x:Bind EndDate}"/>
                                </TextBlock>
                                <TextBlock Text="{x:Bind Accessories}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource NuriyeTextSecondaryBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind SubmittedAt}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource NuriyeTextSecondaryBrush}"
                                       VerticalAlignment="Top"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="2"
                       Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Margin="0,8,0,0"
                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
        </Grid>

        <!-- Processing Panel -->
        <Border Grid.Column="1"
                Background="{ThemeResource NuriyeSurfaceAltBrush}"
                CornerRadius="12"
                Padding="16">
            <ScrollViewer>
                <StackPanel Spacing="12">
                    <TextBlock Text="&#xC2E0;&#xCCAD; &#xCC98;&#xB9AC;"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <TextBlock Text="&#xC120;&#xD0DD;&#xB41C; &#xC2E0;&#xCCAD;&#xC774; &#xC5C6;&#xC2B5;&#xB2C8;&#xB2E4;."
                               Foreground="{ThemeResource NuriyeTextSecondaryBrush}"
                               Visibility="{x:Bind ViewModel.HasNoSelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <StackPanel Spacing="12"
                                Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                                 CornerRadius="10"
                                 x:Name="RentalInfoBar">
                            <InfoBar.Content>
                                <StackPanel Spacing="4" Padding="0,4,0,8">
                                    <TextBlock Text="{x:Bind ViewModel.SelectedRental.Equipment, Mode=OneWay}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Foreground="{ThemeResource NuriyeTextSecondaryBrush}">
                                        <Run Text="{x:Bind ViewModel.SelectedRental.StartDate, Mode=OneWay}"/>
                                        <Run Text=" ~ "/>
                                        <Run Text="{x:Bind ViewModel.SelectedRental.EndDate, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedRental.MeetingTime, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedRental.Accessories, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedRental.ExtraRequest, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"/>
                                </StackPanel>
                            </InfoBar.Content>
                        </InfoBar>

                        <ComboBox Header="&#xB2F4;&#xB2F9;&#xC790;"
                                  ItemsSource="{x:Bind ViewModel.StaffList}"
                                  SelectedItem="{x:Bind ViewModel.SelectedStaff, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  Style="{StaticResource NuriyeComboBoxStyle}"/>

                        <TextBox Header="&#xBE44;&#xACE0;"
                                 Text="{x:Bind ViewModel.Remarks, Mode=TwoWay}"
                                 PlaceholderText="&#xBE44;&#xACE0; &#xC785;&#xB825; (&#xC120;&#xD0DD;)"
                                 AcceptsReturn="True"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 Style="{StaticResource NuriyeTextBoxStyle}"/>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="&#xC2B9;&#xC778;"
                                    Command="{x:Bind ViewModel.ApproveCommand}"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource NuriyeAccentButtonStyle}"/>
                            <Button Grid.Column="1"
                                    Content="&#xBC18;&#xB824;"
                                    Command="{x:Bind ViewModel.RejectCommand}"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource NuriyeDefaultButtonStyle}"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
