<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NuriyeApp.Views.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:models="using:NuriyeApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="&#xC7A5;&#xBE44; &#xBAA9;&#xB85D;"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
            <Button Content="&#xC0C8;&#xB85C;&#xACE0;&#xCE68;"
                    Command="{x:Bind ViewModel.LoadCommand}"
                    Style="{StaticResource NuriyeDefaultButtonStyle}"/>
            <Button Content="&#xD589; &#xCD94;&#xAC00;"
                    Command="{x:Bind ViewModel.AddItemCommand}"
                    Style="{StaticResource NuriyeDefaultButtonStyle}"/>
            <Button Content="&#xC120;&#xD0DD; &#xD589; &#xC0AD;&#xC81C;"
                    Command="{x:Bind ViewModel.RemoveItemCommand}"
                    Style="{StaticResource NuriyeDefaultButtonStyle}"/>
            <Button Content="&#xC800;&#xC7A5;"
                    Command="{x:Bind ViewModel.SaveCommand}"
                    Style="{StaticResource NuriyeAccentButtonStyle}"/>
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="20" Height="20"/>
        </StackPanel>

        <controls:DataGrid
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
            AutoGenerateColumns="False"
            IsReadOnly="False"
            GridLinesVisibility="All"
            AlternatingRowBackground="{ThemeResource NuriyeSurfaceAltBrush}">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="&#xAD6C;&#xBD84;" Binding="{Binding Category}" Width="80"/>
                <controls:DataGridTextColumn Header="&#xCE74;&#xD14C;&#xACE0;&#xB9AC;" Binding="{Binding BodyCategory}" Width="100"/>
                <controls:DataGridTextColumn Header="&#xBE0C;&#xB79C;&#xB4DC;" Binding="{Binding Brand}" Width="100"/>
                <controls:DataGridTextColumn Header="&#xBAA8;&#xB378;&#xBA85;" Binding="{Binding ModelName}" Width="200"/>
                <controls:DataGridTextColumn Header="&#xADDC;&#xACA9;" Binding="{Binding Format}" Width="80"/>
                <controls:DataGridTextColumn Header="&#xC0C1;&#xD0DC;" Binding="{Binding Status}" Width="100"/>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <TextBlock Grid.Row="2"
                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   Margin="0,8,0,0"/>
    </Grid>
</Page>
