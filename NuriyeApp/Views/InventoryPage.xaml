<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NuriyeApp.Views.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:models="using:NuriyeApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 툴바 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="장비 목록"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center"/>
            <Button Content="새로고침" Command="{x:Bind ViewModel.LoadCommand}"/>
            <Button Content="행 추가" Command="{x:Bind ViewModel.AddItemCommand}"/>
            <Button Content="선택 행 삭제" Command="{x:Bind ViewModel.RemoveItemCommand}"/>
            <Button Content="저장"
                    Command="{x:Bind ViewModel.SaveCommand}"
                    Style="{StaticResource AccentButtonStyle}"/>
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="20" Height="20"/>
        </StackPanel>

        <controls:DataGrid
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
            AutoGenerateColumns="False"
            IsReadOnly="False"
            GridLinesVisibility="All"
            AlternatingRowBackground="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="구분" Binding="{Binding Category}" Width="80"/>
                <controls:DataGridTextColumn Header="카테고리" Binding="{Binding BodyCategory}" Width="100"/>
                <controls:DataGridTextColumn Header="브랜드" Binding="{Binding Brand}" Width="100"/>
                <controls:DataGridTextColumn Header="모델명" Binding="{Binding ModelName}" Width="200"/>
                <controls:DataGridTextColumn Header="규격" Binding="{Binding Format}" Width="80"/>
                <controls:DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100"/>
            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <TextBlock Grid.Row="2"
                   Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   Margin="0,8,0,0"/>
    </Grid>
</Page>
