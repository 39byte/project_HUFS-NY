<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NuriyeApp.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Style="{StaticResource NuriyeCardStyle}"
                Width="360">

            <StackPanel Spacing="16">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <TextBlock Text="&#xB204;&#xB9AC;&#xC608; &#xCE74;&#xBA54;&#xB77C; &#xB300;&#xC5EC;"
                               Style="{StaticResource TitleLargeTextBlockStyle}"
                               Foreground="{ThemeResource NuriyeBrandDeepBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="&#xC9D1;&#xD589;&#xBD80; &#xC804;&#xC6A9; &#xAD00;&#xB9AC; &#xC2DC;&#xC2A4;&#xD15C;"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource NuriyeTextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <PasswordBox x:Name="PasswordBox"
                             Header="&#xAD00;&#xB9AC;&#xC790; &#xBE44;&#xBC00;&#xBC88;&#xD638;"
                             PlaceholderText="&#xBE44;&#xBC00;&#xBC88;&#xD638;&#xB97C; &#xC785;&#xB825;&#xD558;&#xC138;&#xC694;"
                             Password="{x:Bind ViewModel.Password, Mode=TwoWay}"
                             KeyDown="PasswordBox_KeyDown"
                             Style="{StaticResource NuriyePasswordBoxStyle}"/>

                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button Content="&#xB85C;&#xADF8;&#xC778;"
                        Command="{x:Bind ViewModel.LoginCommand}"
                        IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource NuriyeAccentButtonStyle}"/>

                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
